# cinterop definition for libbz2 — ships with every iOS install at
# /usr/lib/libbz2.tbd. We bind just enough of the C API to power
# `Bz2.ios.kt`. The full bzlib.h is not in the public iOS SDK, so we
# inline the declarations we need below the `---` separator.
#
# `linkerOpts = -lbz2` adds /usr/lib/libbz2.dylib to every iOS target's
# link line (Native picks the slice from the active SDK automatically).

linkerOpts = -lbz2

---

extern int BZ2_bzBuffToBuffDecompress(
    char* dest,
    unsigned int* destLen,
    char* source,
    unsigned int sourceLen,
    int small,
    int verbosity);

#define BZ_OK 0
#define BZ_RUN_OK 1
#define BZ_FLUSH_OK 2
#define BZ_FINISH_OK 3
#define BZ_STREAM_END 4
#define BZ_SEQUENCE_ERROR -1
#define BZ_PARAM_ERROR -2
#define BZ_MEM_ERROR -3
#define BZ_DATA_ERROR -4
#define BZ_DATA_ERROR_MAGIC -5
#define BZ_IO_ERROR -6
#define BZ_UNEXPECTED_EOF -7
#define BZ_OUTBUFF_FULL -8
#define BZ_CONFIG_ERROR -9
